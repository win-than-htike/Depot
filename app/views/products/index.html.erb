<p id="notice"><%= notice %></p>


<div class="container">

  <h1>Products List</h1>
  <table class="table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Image</th>
        <th>Price</th>
        <th colspan="3"></th>
      </tr>
    </thead>

    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= product.title %></td>
          <td><%= truncate(strip_tags(product.description),length: 80) %></td>
          <td><img src="<%= product.image_url %>" height="42" width="42"/></td>
          <td><%= product.price %></td>
          <td><%= link_to 'Show', product, class:"btn btn-primary" %></td>
          <td><%= link_to 'Edit', edit_product_path(product), class:"btn btn-warning" %></td>
          <td><%= link_to 'Destroy', product, class:"btn btn-danger", method: :delete, data: { confirm: 'Are you sure?' } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

<br>

<%= link_to 'New Product', new_product_path, class:"btn btn-info" %>

</div>
